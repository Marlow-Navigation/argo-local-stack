# Themis (Crewing FE) — local config template.
#
# Copy to ../themis/.env.local and fill in the SECRETS section from the team vault.
# themis runs on the host via `yarn dev` (not in Docker).

# =========================================================================
# BE PROXIES — flip any URL to its staging equivalent if you don't run the BE locally
# =========================================================================
SERVER_API_BASE_URL="http://localhost:8081"                          # local crewing  | staging: https://phoebe-stg.marecrew.com
KH_API_BASE_URL="http://localhost:8081"                              # local crewing  | staging: https://phoebe-stg.marecrew.com
DEBRIEFING_API_BASE_URL="http://localhost:8082"                      # local alcyone  | staging: https://alcyone-api-stg.marecrew.com
AUTH_API_URL="https://ps-auth-stg.marecrew.com"                      # no local ps-auth
PS_BASE_URL="https://ps-ca-stg.marecrew.com"
UM_BASE_URL="https://users-api-stg.marecrew.com"
TM_BASE_URL="https://tasks-stg.marecrew.com"
AUDIT_LOG_API_BASE_URL="https://audit-logs-stg.marecrew.com"
DOCUMENTS_BASE_URL="https://documents-api-stg.marecrew.com"
INSURANCE_API_BASE_URL="https://insurance-api-stg.marecrew.com"
HERMES_API_URL="https://ps-hermes-stg.marecrew.com"
PS_IO_API_BASE_URL="https://ps-io-stg.marecrew.com"
POI_API_BASE_URL="https://point-of-interest.marlowgroup.io"

# =========================================================================
# CLIENT-SIDE
# =========================================================================
NEXT_PUBLIC_KEYCLOAK_URL="https://keycloak.marecrew.com"
NEXT_PUBLIC_THEMIS_URL="http://localhost:3001"
NEXT_PUBLIC_KEYCLOAK_REALM="odyssey"
NEXT_PUBLIC_KEYCLOAK_CLIENTID="cerberus"
NEXT_PUBLIC_MAPBOX_MAP_STYLE="mapbox://styles/<your-mapbox-account>/<style-id>"
NEXT_PUBLIC_AIS_MANAGER_URL="https://point-of-interest.marlowgroup.io"
NEXT_PUBLIC_USE_AIS_MANAGER="true"
SPIRE_API_BASE_URL="https://spire.marecrew.com"

# =========================================================================
# NEXTAUTH
# =========================================================================
NEXTAUTH_URL="http://localhost:3001"
LOGS_LEVEL="debug"

# =========================================================================
# PROXY BEHAVIOUR
# =========================================================================
NODE_TLS_REJECT_UNAUTHORIZED=0
REACT_PROXY_CHANGE_ORIGIN=true
REACT_PROXY_SECURE=true
PORT=3001

# =========================================================================
# SECRETS — fill from vault
# =========================================================================

# Bounces login → "Invalid parameter: redirect_uri" if Keycloak's `cerberus` client doesn't whitelist
# this PORT. Themis on 3001 is already whitelisted in stg; if you change PORT ask a Keycloak admin.
KEYCLOAK_CLIENT_SECRET=""
NEXTAUTH_SECRET=""

# Expired MUI X Pro keys THROW in dev → "Something went wrong!" on every grid page. Use an unexpired key.
NEXT_PUBLIC_MUI_LICENSE_KEY=""

NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""
POI_API_KEY=""
NEXT_PUBLIC_AIS_MANAGER_API_KEY=""
JIRA_HELPDESK_TOKEN=""
