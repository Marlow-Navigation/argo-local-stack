# Marlow dev stack — local config template.
#
# Copy to `.env.local` and fill in the SECRETS section from your team vault.
# Everything else has working defaults; tweak only if you hit conflicts.
#
# `.env.local` is gitignored — do not commit secrets.

# =========================================================================
# CORE
# =========================================================================
ENVIRONMENT=dev
DOCKER_TAG=1.0.570                 # phoebe release tag — parent pom reads ${env.DOCKER_TAG}; any non-empty string works
NEXUS_REPO=nexus.marecrew.com

# =========================================================================
# LOCAL DB (host port remapped to 5433 — host often has its own Postgres on 5432)
# =========================================================================
POSTGRES_PORT=5433
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://postgres:5432/postgres   # container-internal hostname; do not change
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=crewing
DB_THREAD_POOL_SIZE=32

# =========================================================================
# SERVICE PORTS
# =========================================================================
CREWING_PORT=8081
ALCYONE_PORT=8082
ALCYONE_DOCKER_TAG=1.0.0
ALCYONE_DB_SCHEMA=debriefing

# =========================================================================
# STAGING SERVICE URLS (crewing's outbound dependencies)
# =========================================================================
CORE_URL=https://core-proxy.marecrew.com/api/
FALLBACK_URL=https://commons-oracle-proxy.apps.marlow.naboocore.com/api
POSEIDON_IO_URL=https://ps-io-stg.marecrew.com
POSEIDON_KHARON_URL=https://ps-kh-stg.marecrew.com
POSEIDON_MISC_URL=https://ps-ca-stg.marecrew.com
PS_HERMES_URL=https://ps-hermes-stg.marecrew.com
CREW_COMPANION_URL=https://cca-stg.marecrew.com
API_VERSION=11/
TASK_MANAGEMENT_URL=https://tasks-stg.marecrew.com
DOCUMENT_SERVICE_URL=https://documents-api-stg.marecrew.com
CLIENT_PORTAL_BASE_URL=https://client-portal-stg.marecrew.com
FLAG_CHARGES_URL=https://flag-charges.marecrew.com
FUZZY_SEARCH_URL=https://fuzzysearcher-stg.marecrew.com
SSO_AUTH_VALIDATOR_URL=https://ps-auth-stg.marecrew.com
PEM_KEY=https://keycloak.marecrew.com/realms/odyssey
REALM_CLIENT=cerberus
RELATIVE_WORKFLOW_URL=test

# =========================================================================
# TRACING (local Jaeger container)
# =========================================================================
JAEGER_HOST=jaeger
JAEGER_PORT=14268
JAEGER_PROTOCOL=http

# =========================================================================
# SSO — JWK set URLs (NOT realm base!)
# phoebe uses NimbusJwtDecoder.withJwkSetUri(value) directly, so each MUST be the
# /protocol/openid-connect/certs endpoint, not the realm root.
# =========================================================================
SSO_ODYSSEY_ISSUER_URL=https://keycloak.marecrew.com/realms/odyssey/protocol/openid-connect/certs
SSO_SEAFARER_ISSUER_URL=https://keycloak.marecrew.com/realms/seafarer/protocol/openid-connect/certs
SSO_CREWAPI_ISSUER_URL=https://keycloak.marecrew.com/realms/crewapi/protocol/openid-connect/certs
SSO_CLIENT_ISSUER_URL=https://keycloak.marecrew.com/realms/client/protocol/openid-connect/certs
SSO_VESSEL_ISSUER_URL=https://keycloak.marecrew.com/realms/vessel/protocol/openid-connect/certs
SSO_REALM_LOGIN_URL=https://keycloak.marecrew.com
PS_AUTH_SA_LOGIN=https://ps-auth-stg.marecrew.com
KEYCLOAK_SSO_ENDPOINT=https://keycloak.marecrew.com/realms/odyssey/protocol/openid-connect/token

# =========================================================================
# KAFKA (local, PLAINTEXT — SSL fields intentionally empty)
# =========================================================================
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SSL_TRUSTSTORE_LOCATION=
KAFKA_SSL_TRUSTSTORE_PASSWORD=
KAFKA_SSL_KEYSTORE_LOCATION=
KAFKA_SSL_KEYSTORE_PASSWORD=
SSL_KEY_PASSWORD=
AUDIT_EVENTS_TOPIC=crewing-audit-logs-topic-dev
KAFKA_AUDIT_LOGS_TOPIC_NAME=crewing-audit-logs-topic-dev
KAFKA_TOPICS=crewing-audit-logs-topic-dev,surveys-audit-log-topic-dev,task-audit-log-topic-dev,gl-notifications-stg,gl-inbound-main,gl-inbound-main-dlq

# =========================================================================
# ALCYONE topics + service URLs
# =========================================================================
GL_NOTIFICATIONS_TOPIC=gl-notifications-stg
GL_INBOUND_MAIN_TOPIC=gl-inbound-main
GL_INBOUND_MAIN_DLQ=gl-inbound-main-dlq
SURVEYS_AUDIT_LOGS_TOPIC=surveys-audit-log-topic-dev
ALCYONE_FILE_SERVICE=https://alcyone-api-stg.marecrew.com
ALCYONE_GATEWAY_SERVICE=https://phoebe-stg.marecrew.com
CREWING_URL=http://crewing:8080
ENABLE_ORACLE_CALLS=false

# =========================================================================
# CREWING ORACLE DEFAULTS (from team vault — required if ENABLE_ORACLE_CALLS=true)
# =========================================================================
CREWING_DEFAULT_ORACLE_IDENTITY=systemargo
CREWING_DEFAULT_ORACLE_GROUP=AA

# =========================================================================
# SECRETS — fill from vault. Empty values mean specific endpoints will 401/500.
# =========================================================================

# alcyone S2S key (x-api-key on every outbound call). EMPTY = debriefing endpoints 500.
SURVEYS_INTERNAL_SA=

# Alcyone feature flag (the team's "migration_debriefing" identifier — get from a teammate)
migration_debriefing=

# Crewing S2S secrets — needed for ps-auth feature-check calls & internal endpoints
CREWING_SSO_SA_KEY=
CREWING_INTERNAL_API_KEY=

# Third-party integration keys
CORE_API_KEY=
FLAG_CHARGES_API_KEY=
FUZZY_SEARCH_API_KEY=
FUZZY_SEARCH_THRESHOLD=80
FUZZY_SEARCH_LIMIT=50
