DOCKER_TAG=latest
ENVIRONMENT=dev

# Database
DB_URL=jdbc:postgresql://postgres:5432/postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver
DB_SCHEMA=imports
DB_THREAD_POOL_SIZE=32

# SSO / Keycloak
SSO_CREWAPI_ISSUER_URL=https://keycloak.marecrew.com/realms/crewapi/protocol/openid-connect/certs
SSO_CREWAPI_REALM_LOGIN_URL=
SSO_AUTH_VALIDATOR_URL=https://ps-auth-stg.marecrew.com
PS_AUTH_SA_LOGIN=

# Jaeger
JAEGER_HOST=jaeger
JAEGER_PORT=4318
JAEGER_PROTOCOL=http

# Services
ORACLE_CORE_PROXY=https://core-proxy.marecrew.com/api/
PS_IO_URL=https://ps-io-stg.marecrew.com
CREWING_URL=http://phoebe-crewing:8080
CREWING_SSO_SA_KEY=
