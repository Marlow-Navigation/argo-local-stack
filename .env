# Core database
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=58080

# Kafka
KAFKA_PORT=9092
KAFKA_UI_PORT=58081
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:29092,PLAINTEXT_HOST://0.0.0.0:9092
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_UI_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_PARTITIONS=1
KAFKA_TOPIC_REPLICATION_FACTOR=1
# Comma-separated list of topics to auto-create
KAFKA_TOPICS=crewing-audit-logs-topic-dev,surveys-audit-log-topic-dev,task-audit-log-topic-dev,gl-notifications-stg,gl-inbound-main,gl-inbound-main-dlq

# Argo DB app
ARGO_DB_BRANCH=master
DB_URL=jdbc:postgresql://postgres:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Phoebe services (profile: phoebe)
PHOEBE_CREWING_PORT=8090
PHOEBE_TRAINING_PORT=8091
PHOEBE_DOCUMENT_PORT=8092
PHOEBE_TASK_MANAGEMENT_PORT=8093
PHOEBE_AUDIT_LOGS_PORT=8094
PHOEBE_USER_MANAGEMENT_PORT=8095
PHOEBE_IMPORTS_PORT=8096
PHOEBE_INSURANCE_PORT=8097
PHOEBE_INTEGRATION_CLIENT_PORT=8098
