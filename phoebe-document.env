# Database (overrides)
DB_SCHEMA=document

# SSO / Keycloak (additional realms)
SSO_SEAFARER_ISSUER_URL=https://keycloak.marecrew.com/realms/seafarer/protocol/openid-connect/certs

# Async executor
ASYNC_CORE_POOL_SIZE=5
ASYNC_MAX_POOL_SIZE=10
ASYNC_QUEUE_CAPACITY=25
ASYNC_THREAD_NAME_PREFIX=DocAsync-

# Services
CREWING_URL=http://phoebe-crewing:8080
CORE_URL=https://core-proxy.marecrew.com/api/
