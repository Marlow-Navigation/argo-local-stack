DOCKER_TAG=latest
ENVIRONMENT=dev

# Database
DB_URL=jdbc:postgresql://postgres:5432/postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver
DB_SCHEMA=crewing
DB_THREAD_POOL_SIZE=5

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
SSL_KEY_PASSWORD=changeit
KAFKA_SSL_TRUSTSTORE_LOCATION=
KAFKA_SSL_TRUSTSTORE_PASSWORD=changeit
KAFKA_SSL_KEYSTORE_LOCATION=
KAFKA_SSL_KEYSTORE_PASSWORD=changeit
AUDIT_EVENTS_TOPIC=task-management-audit-logs
KAFKA_AUDIT_LOGS_TOPIC_NAME=task-audit-log-topic-dev

# SSO / Keycloak
SSO_ODYSSEY_ISSUER_URL=https://keycloak.marecrew.com/realms/odyssey/protocol/openid-connect/certs
SSO_SEAFARER_ISSUER_URL=https://keycloak.marecrew.com/realms/seafarer/protocol/openid-connect/certs
SSO_CREWAPI_ISSUER_URL=https://keycloak.marecrew.com/realms/crewapi/protocol/openid-connect/certs
SSO_REALM_CERTS_URL=https://keycloak.marecrew.com/realms/odyssey/protocol/openid-connect/certs
SSO_AUTH_VALIDATOR_URL=https://ps-auth-stg.marecrew.com
SSO_REALM_LOGIN_URL=
PS_AUTH_SA_LOGIN=

# Services
API_VERSION=v1
CORE_API_KEY=changeit
CORE_URL=https://core-proxy.marecrew.com/api/
CREW_COMPANION_URL=https://cca-stg.marecrew.com/api
CREWING_URL=http://phoebe-crewing:8080
FALLBACK_URL=http://phoebe-crewing:8080
FUZZY_SEARCH_API_KEY=changeit
FUZZY_SEARCH_URL=https://fuzzysearcher-stg.marecrew.com/api/v1
POSEIDON_IO_URL=https://ps-io-stg.marecrew.com
POSEIDON_KHARON_URL=https://ps-kh-stg.marecrew.com
POSEIDON_MISC_URL=test
RELATIVE_WORKFLOW_URL=https://commons-oracle-proxy.apps.marlow.naboocore.com/api/
TASK_MANAGEMENT_URL=http://phoebe-task-management:8080
PSD_PHOEBE_API_KEY=
XAPI_KEY=
